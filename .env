# For Prisma build time - just needs a valid SQLite URL format
# The real Turso URL is used at runtime via the adapter
DATABASE_URL=file:./dev.db

# Turso cloud (used at runtime via @prisma/adapter-libsql)
# Set these on Vercel Environment Variables - do NOT put real tokens here
# TURSO_URL=libsql://trackr-db-foyrasel.aws-ap-south-1.turso.io
# DATABASE_AUTH_TOKEN=your-turso-token

NEXTAUTH_SECRET=testsecret1234567890
NEXTAUTH_URL=http://localhost:3000
