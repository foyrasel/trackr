generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  password       String?   // hashed password for email auth
  image          String?
  provider       String    @default("demo") // "google", "facebook", "apple", "demo", "email"
  darkMode       Boolean   @default(false)
  currency       String    @default("USD") // ISO 4217 currency code
  currencySymbol String    @default("$") // Display symbol
  accounts       Account[]
  transfers      Transfer[]
  budgets        Budget[]
  transactions   Transaction[]
  recurringTxns  RecurringTransaction[]
  goals          Goal[]
  reminders      Reminder[]
  lendBorrows    LendBorrow[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   // "Cash", "Debit Card", "Credit Card", "bKash", "Nagad", etc.
  type      String   // "cash", "debit", "credit", "mobile" (bKash/Nagad)
  balance   Float    @default(0)
  color     String   @default("#10b981")
  icon      String   @default("💵")
  isDefault Boolean  @default(false)
  fromTransfers Transfer[] @relation("FromAccount")
  toTransfers   Transfer[] @relation("ToAccount")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transfer {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccountId String
  fromAccount Account @relation("FromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccountId   String
  toAccount   Account @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)
  amount      Float    // Amount transferred
  description String   @default("Transfer") // Note about the transfer
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String   // Email address being verified
  token      String   // 6-digit verification code
  expires    DateTime // When the token expires
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month        String   // "2026-06" format
  category     String   // "Groceries", "Transport", etc. or "total" for overall
  amount       Float    // budget amount
  isIgnored    Boolean  @default(false) // user can ignore/skip budget
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, month, category])
}

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String   // "expense" or "income"
  amount         Float
  description    String
  category       String   // e.g., "Groceries", "Transport", "Salary"
  spendingType   String   @default("cash") // "cash", "debit", "credit", "mobile"
  classification String   @default("need") // "need", "want", "ego", "savings", "debt" (for expenses), "income" (for income)
  date           DateTime @default(now())
  isRecurring    Boolean  @default(false)
  receiptUrl     String?  // Path to uploaded receipt photo
  recurringId    String?  // Link to recurring transaction that created this
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RecurringTransaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String   // "expense" or "income"
  amount         Float
  description    String
  category       String
  spendingType   String   @default("cash")
  classification String   @default("need")
  frequency      String   // "daily", "weekly", "monthly", "yearly"
  dayOfMonth     Int      @default(1) // For monthly: which day (1-31)
  dayOfWeek      Int?     // For weekly: which day (0=Sun, 6=Sat)
  startDate      DateTime @default(now())
  endDate        DateTime? // null = forever
  lastExecuted   DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String   // e.g., "Save for Eid", "Emergency Fund"
  targetAmount Float    // Goal amount in BDT
  savedAmount  Float    @default(0) // How much saved so far
  deadline     DateTime? // Target date
  icon         String   @default("🎯")
  color        String   @default("#10b981")
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   // e.g., "Pay Electricity Bill"
  amount      Float?   // Expected amount
  category    String   @default("Utilities")
  dueDate     DateTime // When the bill is due
  remindDays  Int      @default(3) // Remind N days before due date
  isRecurring Boolean  @default(false)
  frequency   String?  // "monthly", "yearly" if recurring
  isPaid      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LendBorrow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "lend" or "borrow"
  amount      Float    // Amount lent or borrowed
  person      String   // Name of the person
  description String   // Reason / note
  date        DateTime // When the lending/borrowing happened
  dueDate     DateTime? // When the money should be returned
  isSettled   Boolean  @default(false) // Whether the amount has been paid back
  settledDate DateTime? // When it was actually settled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
